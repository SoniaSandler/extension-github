{
  "name": "github-account",
  "repository": "https://github.com/podman-desktop/extension-github",
  "homepage": "https://github.com/podman-desktop/extension-github#readme",
  "displayName": "GitHub Account Authentication",
  "description": "Sign in and authenticate with a GitHub account",
  "version": "0.3.0-next",
  "icon": "icon.png",
  "publisher": "podman-desktop",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": "^1.19.0"
  },
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "format:check": "biome format",
    "format:fix": "biome format --write",
    "lint:check": "eslint . && biome lint",
    "lint:fix": "eslint . --fix && biome lint --fix",
    "watch": "vite build -w",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<1.1.14": ">=1.1.14 <2"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@octokit/rest": "^22.0.1",
    "@podman-desktop/api": "1.27.1",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-file-progress": "^4.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^3.2.4"
  }
}
